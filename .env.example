# ══════════════════════════════════════════════════════════════
# ForgeMind Environment Configuration
# Copy this file to .env and fill in your values.
# ══════════════════════════════════════════════════════════════

# ── Application ──────────────────────────────────────────────
FORGEMIND_ENV=development
FORGEMIND_DEBUG=true
FORGEMIND_LOG_LEVEL=DEBUG
FORGEMIND_LOG_FORMAT=console
FORGEMIND_HOST=127.0.0.1
FORGEMIND_PORT=8000
FORGEMIND_DATA_DIR=data

# ── LLM Provider ────────────────────────────────────────────
LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=sk-your-key-here
LLM_BASE_URL=https://api.openai.com/v1
LLM_MAX_TOKENS=2000
LLM_TEMPERATURE=0.1

# ── Knowledge Graph Storage ─────────────────────────────────
GRAPH_BACKEND=networkx
GRAPH_PERSISTENCE_PATH=data/graph.json
# Neo4j settings (V2)
# GRAPH_NEO4J_URI=bolt://localhost:7687
# GRAPH_NEO4J_USER=neo4j
# GRAPH_NEO4J_PASSWORD=your-password-here

# ── Vector Store ────────────────────────────────────────────
VECTOR_BACKEND=chromadb
VECTOR_PERSIST_DIRECTORY=data/chromadb
VECTOR_EMBEDDING_MODEL=all-MiniLM-L6-v2
VECTOR_COLLECTION_NAME=forgemind_chunks
