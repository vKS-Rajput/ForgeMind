# ══════════════════════════════════════════════════════════════
# ForgeMind Test Environment
# Used by CI and local test runs. No secrets, no external calls.
# ══════════════════════════════════════════════════════════════

FORGEMIND_ENV=testing
FORGEMIND_DEBUG=true
FORGEMIND_LOG_LEVEL=WARNING
FORGEMIND_LOG_FORMAT=console
FORGEMIND_DATA_DIR=data/test

LLM_PROVIDER=openai
LLM_MODEL_NAME=gpt-4o-mini
LLM_API_KEY=sk-test-not-a-real-key
LLM_MAX_TOKENS=100
LLM_TEMPERATURE=0.0

GRAPH_BACKEND=networkx
GRAPH_PERSISTENCE_PATH=data/test/graph.json

VECTOR_BACKEND=chromadb
VECTOR_PERSIST_DIRECTORY=data/test/chromadb
VECTOR_COLLECTION_NAME=forgemind_test
